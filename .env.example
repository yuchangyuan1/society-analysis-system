# Society Analysis - environment template (v2)
# Copy to `.env` and fill in real values. .env is gitignored.
#
# Only the variables under [REQUIRED] must be filled in for the system to
# come up via `docker compose up`. Everything else has sensible defaults.

# ─── [REQUIRED] LLM access ──────────────────────────────────────────────────
# OpenAI is used for: query rewriting, NL2SQL prompt, report writing,
# critic, and embedding generation (text-embedding-3-small).
OPENAI_API_KEY=sk-...

# ─── [OPTIONAL] LLM model selection ─────────────────────────────────────────
# Override only if you want a different chat model. Embeddings use the
# OpenAI default and are not configurable here.
OPENAI_MODEL=gpt-4o

# ─── [OPTIONAL] Anthropic for multimodal enrichment ─────────────────────────
# Used for image / video posts when MULTIMODAL_DAILY_BUDGET_USD is non-zero.
# Leave blank to skip multimodal entirely.
ANTHROPIC_API_KEY=

# ─── Postgres ───────────────────────────────────────────────────────────────
# Local Python runs use localhost. Docker Compose overrides this to
# postgresql://society:society_pass@postgres:5432/society_db inside containers.
POSTGRES_DSN=postgresql://society:society_pass@localhost:5432/society_db
POSTGRES_READONLY_DSN=

# ─── Storage paths ──────────────────────────────────────────────────────────
# Inside the Docker stack these are bind-mounted to ./data on the host, so
# Chroma / Kuzu / runs survive `docker compose down`.
CHROMA_PERSIST_DIR=./data/chroma
KUZU_DB_DIR=./data/kuzu_graph
RUNS_DIR=./data/runs

# ─── Chroma collections ─────────────────────────────────────────────────────
CHROMA_OFFICIAL_COLLECTION=chroma_official
CHROMA_NL2SQL_COLLECTION=chroma_nl2sql
CHROMA_PLANNER_COLLECTION=chroma_planner

# ─── NL2SQL safety + repair limits ──────────────────────────────────────────
NL2SQL_MAX_REPAIR_ROUNDS=3
NL2SQL_RESULT_ROW_LIMIT=1000
NL2SQL_STATEMENT_TIMEOUT_MS=5000

# ─── Conflict-replacement thresholds (Chroma 2 / Chroma 3 dedup) ────────────
NL2SQL_CONFLICT_SIM_LOW=0.92
NL2SQL_CONFLICT_SIM_HIGH=0.95

# ─── Experience decay ───────────────────────────────────────────────────────
EXPERIENCE_TTL_DAYS=30
EXPERIENCE_MIN_CONFIDENCE=0.2

# ─── KG topic-name fallback ─────────────────────────────────────────────────
# For propagation/reply-chain/amplifier questions, the agent may try nearby
# topics when the exact semantic match has no Kuzu graph signal.
KG_TOPIC_SEMANTIC_FALLBACK_MIN_SIM=0.30

# ─── Session context window ─────────────────────────────────────────────────
SESSION_MAX_TURNS=40
SESSION_MIN_TURNS_TO_COMPACT=10
SESSION_SUMMARY_MAX_CHARS=1200

# ─── Multimodal sampling + budget ───────────────────────────────────────────
MULTIMODAL_DAILY_BUDGET_USD=5.0
MULTIMODAL_COST_PER_CALL_USD=0.02
MULTIMODAL_MIN_LIKES=50
MULTIMODAL_MIN_REPLIES=20

# ─── Reddit community ingestion ─────────────────────────────────────────────
# This project scrapes public Reddit pages; no API credentials are needed.
# Set REDDIT_PROXY only if your network blocks reddit.com directly.
# REDDIT_PROXY=http://127.0.0.1:7890
REDDIT_DEFAULT_SUBREDDITS=conspiracy,worldnews,politics,health,news

# ─── System ─────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ─── Streamlit UI -> FastAPI ────────────────────────────────────────────────
# Inside Docker, compose overrides RESEARCH_API_BASE to http://api:8000.
RESEARCH_API_BASE=http://127.0.0.1:8000
# Short read timeout for GETs (/health, /runs, /report).
RESEARCH_API_TIMEOUT=10
# Long read timeout for orchestration POSTs (/chat/query, /admin/import).
# /chat/query runs rewriter -> planner -> 2-3 branches -> writer -> critic
# and routinely takes 1-3 minutes; do not set below 120.
RESEARCH_API_LONG_TIMEOUT=240
