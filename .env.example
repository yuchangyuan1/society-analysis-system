# ── Anthropic ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── OpenAI (embeddings only: text-embedding-3-small) ──────────────────────────
OPENAI_API_KEY=sk-...

# ── X (Twitter) API v2 ────────────────────────────────────────────────────────
X_BEARER_TOKEN=...
X_API_KEY=...
X_API_SECRET=...
X_ACCESS_TOKEN=...
X_ACCESS_TOKEN_SECRET=...

# ── Postgres ───────────────────────────────────────────────────────────────────
POSTGRES_DSN=postgresql://user:password@localhost:5432/society_db

# ── Chroma ─────────────────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./data/chroma

# ── Kuzu ───────────────────────────────────────────────────────────────────────
KUZU_DB_DIR=./data/kuzu_graph

# ── Raw media / visual outputs ─────────────────────────────────────────────────
RAW_MEDIA_DIR=./data/raw_media
COUNTER_VISUALS_DIR=./data/counter_visuals

# ── Stable Diffusion ───────────────────────────────────────────────────────────
# Set to a Hugging Face model ID or local path, e.g.:
#   stabilityai/stable-diffusion-2-1
SD_MODEL_ID=stabilityai/stable-diffusion-2-1
# Set to "cuda", "mps", or "cpu"
SD_DEVICE=cpu

# ── System ─────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
