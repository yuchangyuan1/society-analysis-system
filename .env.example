# ───────────────────────────────────────────────────────────────────────────
# Society Analysis - environment template (v2)
# Copy to `.env` and fill in real values. .env is gitignored.
# ───────────────────────────────────────────────────────────────────────────

# ── LLM + embedding (REQUIRED) ────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
# Embedding model is hard-coded to text-embedding-3-small (1536 dim).

# ── Multimodal (OPTIONAL) ─────────────────────────────────────────────────
# Used by agents/multimodal_agent.py. The pipeline degrades gracefully
# when this is missing; image content just isn't folded into post text.
ANTHROPIC_API_KEY=sk-ant-...

# ── Postgres ──────────────────────────────────────────────────────────────
POSTGRES_DSN=postgresql://society:society_pass@localhost:5432/society_db
# Recommended: separate read-only role for NL2SQL. Falls back to
# POSTGRES_DSN when blank.
POSTGRES_READONLY_DSN=

# ── Storage paths ─────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./data/chroma
KUZU_DB_DIR=./data/kuzu_graph
RUNS_DIR=./data/runs

# ── Chroma collections (rename if you run multiple deployments) ───────────
CHROMA_OFFICIAL_COLLECTION=chroma_official
CHROMA_NL2SQL_COLLECTION=chroma_nl2sql
CHROMA_PLANNER_COLLECTION=chroma_planner

# ── NL2SQL safety + repair limits ─────────────────────────────────────────
NL2SQL_MAX_REPAIR_ROUNDS=3
NL2SQL_RESULT_ROW_LIMIT=1000
NL2SQL_STATEMENT_TIMEOUT_MS=5000

# ── Conflict-replacement thresholds (Chroma 2/3) ──────────────────────────
NL2SQL_CONFLICT_SIM_LOW=0.92
NL2SQL_CONFLICT_SIM_HIGH=0.95

# ── Experience decay (decay_chroma_experience.py) ─────────────────────────
EXPERIENCE_TTL_DAYS=30
EXPERIENCE_MIN_CONFIDENCE=0.2

# ── Multimodal sampling + budget ──────────────────────────────────────────
MULTIMODAL_DAILY_BUDGET_USD=5.0
MULTIMODAL_COST_PER_CALL_USD=0.02
# Only run image understanding on posts above either threshold:
MULTIMODAL_MIN_LIKES=50
MULTIMODAL_MIN_REPLIES=20

# ── Reddit (community ingestion; OPTIONAL; uses public JSON API) ──────────
# REDDIT_PROXY=http://127.0.0.1:7890
REDDIT_DEFAULT_SUBREDDITS=conspiracy,worldnews,politics,health,news

# ── Telegram (community ingestion; OPTIONAL) ──────────────────────────────
# Only needed if you pass --channel to main.py.
# TELEGRAM_API_ID=
# TELEGRAM_API_HASH=
# TELEGRAM_SESSION_PATH=./data/telegram_session

# ── System ────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
