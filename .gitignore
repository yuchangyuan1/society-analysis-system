# ───────────────────────────────────────────────────────────────────────────
# Society Analysis - .gitignore (v2)
# ───────────────────────────────────────────────────────────────────────────

# ── Secrets / credentials (never commit) ──────────────────────────────────
.env
.env.local
.env.*.local
*.pem
*.key
*.session
*.session-journal

# ── Python ────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
.eggs/
build/
dist/
develop-eggs/
pip-log.txt

# ── Virtual environments ──────────────────────────────────────────────────
.venv/
venv/
env/
ENV/
.python-version

# ── Test / coverage ───────────────────────────────────────────────────────
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
.cache
.hypothesis/
coverage.xml

# ── Type checking / linting ───────────────────────────────────────────────
.mypy_cache/
.dmypy.json
.pyre/
.ruff_cache/

# ── Editors / IDEs ────────────────────────────────────────────────────────
.vscode/
.idea/
.cursor/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini

# ── Jupyter ───────────────────────────────────────────────────────────────
.ipynb_checkpoints/

# ── Claude Code / local agent state ───────────────────────────────────────
.claude/

# ── Project runtime data ──────────────────────────────────────────────────
# The pre-loaded snapshot ships with the repo so the grader can use the
# system end-to-end after `docker compose up` — without re-running
# ingestion. Concretely we commit:
#   data/chroma/          — 3 Chroma collections (HNSW indexes)
#   data/kuzu_graph       — Kuzu graph DB (single binary file)
#   data/official_chunks/ — JSONL of fetched RSS items per source
#   db/snapshot_data.sql.gz — pg_dump that initdb auto-restores on first boot
# The runtime-only artifacts below are ignored (they are produced per
# session and have no value to ship):
data/runs/
data/sessions/
data/kuzu_graph.wal
data/kuzu_graph.lock
data/*.db
data/*.jsonl
data/*.png
data/*.jpg
data/*.jpeg
data/*.webp

# ── Streamlit ─────────────────────────────────────────────────────────────
.streamlit/secrets.toml

# ── Logs ──────────────────────────────────────────────────────────────────
*.log
logs/

# ── Tests: ignore user-local fixtures, keep committed ones ────────────────
tests/fixtures/local_*

# ── Build / deploy ────────────────────────────────────────────────────────
*.pid
*.sock
.docker/
.terraform/
*.tfstate
*.tfstate.*
